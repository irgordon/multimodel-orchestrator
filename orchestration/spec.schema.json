{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://orchestration/schemas/spec.schema.json",
  "title": "SpecSchema",
  "description": "Canonical schema for spec.yaml — produced in Phase 0 (Problem Intake). Immutable after Phase 0 boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_version", "run_id_seed", "goals", "constraints", "invariants", "risk_notes"],
  "properties": {
    "spec_version": {
      "type": "string",
      "description": "Schema version identifier. MUST be 'v3'.",
      "enum": ["v3"]
    },
    "run_id_seed": {
      "type": "object",
      "description": "Inputs used to derive run_id via SHA-256 hashing.",
      "additionalProperties": false,
      "required": ["toolchain_version", "model_identifiers"],
      "properties": {
        "toolchain_version": {
          "type": "string",
          "description": "Exact toolchain version string (semver or commit hash).",
          "minLength": 1
        },
        "model_identifiers": {
          "type": "object",
          "description": "Stable JSON map from role name to model name+version.",
          "additionalProperties": false,
          "properties": {
            "planner": { "$ref": "#/definitions/ModelIdentifier" },
            "generator": { "$ref": "#/definitions/ModelIdentifier" },
            "diff_model": { "$ref": "#/definitions/ModelIdentifier" }
          }
        }
      }
    },
    "goals": {
      "type": "array",
      "description": "Ordered list of high-level objectives for this run.",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^goal-[a-z0-9_-]+$" },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "constraints": {
      "type": "array",
      "description": "Hard constraints that must not be violated by any task.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^constraint-[a-z0-9_-]+$" },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "invariants": {
      "type": "array",
      "description": "Global invariant predicate references that apply to every task.",
      "items": { "$ref": "#/definitions/InvariantRef" }
    },
    "risk_notes": {
      "type": "array",
      "description": "Known risk observations captured during problem intake.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "risk_level", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^risk-[a-z0-9_-]+$" },
          "risk_level": { "type": "integer", "minimum": 0, "maximum": 3 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "author": { "type": "string" }
      }
    }
  },
  "definitions": {
    "ModelIdentifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "InvariantRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["predicate_id", "parameters"],
      "properties": {
        "predicate_id": { "type": "string", "minLength": 1 },
        "parameters": { "type": "object" }
      }
    }
  }
}
